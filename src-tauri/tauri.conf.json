{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Research Inbox",
  "version": "0.1.0",
  "identifier": "com.omniboard.research-inbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Research Inbox",
        "url": "/",
        "width": 380,
        "height": 560,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "Capture",
        "url": "/overlay.html",
        "width": 420,
        "height": 56,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.research-inbox/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "resources": ["scripts/ocr", "scripts/get_selected_text", "scripts/simulate_copy", "scripts/clipboard_read"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
